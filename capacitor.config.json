{
  "appId":    "com.emp.enterprisemanagement",
  "appName":  "Enterprise Management Pro",
  "webDir":   ".",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor":    "#0f172a",
      "showSpinner":        false
    },
    "StatusBar": {
      "style":           "Dark",
      "backgroundColor": "#0f172a"
    }
  },
  "server": {
    "allowNavigation": [
      "*.firebaseio.com",
      "*.googleapis.com",
      "*.gstatic.com",
      "cdn.tailwindcss.com",
      "cdnjs.cloudflare.com",
      "cdn.jsdelivr.net"
    ]
  }
}
